# Codebot 环境变量配置

# 应用 Token (用于 API 认证)
APP_TOKEN=replace-with-a-strong-random-token

# OpenCode Server 地址
OPENCODE_SERVER_URL=http://127.0.0.1:11200

# 网络配置
NETWORK_HOST=0.0.0.0
NETWORK_PORT=15682

# 飞书配置 (可选)
LARK_APP_ID=
LARK_APP_SECRET=
LARK_WEBHOOK_URL=

# 邮箱配置 (可选)
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
