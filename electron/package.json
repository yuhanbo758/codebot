{
  "name": "codebot",
  "version": "3.4.0",
  "description": "基于 OpenCode 的个人 AI 助手",
  "author": "Codebot",
  "main": "main.js",
  "scripts": {
    "start": "chcp 65001 && electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "ai.codebot.app",
    "productName": "Codebot",
    "directories": {
      "output": "dist/electron_new"
    },
    "files": [
      "main.js",
      "preload.js",
      "loading.html"
    ],
    "extraResources": [
      {
        "from": "../backend/dist_build/codebot-backend",
        "to": "backend/codebot-backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../README.md",
        "to": "README.md"
      },
      {
        "from": "../skills",
        "to": "skills",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/opencode",
        "to": "opencode",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "zip"
      ]
    },
    "win": {
      "icon": "../logo.ico",
      "signingHashAlgorithms": null,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "Codebot-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "Codebot-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "artifactName": "Codebot-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "yuhanbo758",
        "repo": "codebot"
      }
    ]
  }
}
